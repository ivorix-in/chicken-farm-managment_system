# Local Postgres — or Neon (pooled endpoint: add ?sslmode=require&pgbouncer=true; do not use channel_binding with the pooler).
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech:5432/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradeauct?schema=public"
JWT_SECRET="replace-with-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"
PORT=9000
NODE_ENV=development

# Branding & password reset
APP_NAME="Chicken Farm Management"
# Optional: admin SPA URL for email CTA (e.g. https://admin.example.com)
# APP_PUBLIC_URL="https://localhost:3000"
# Optional: seller SPA URL for seller password-reset emails
# SELLER_APP_PUBLIC_URL="http://localhost:5173"
PASSWORD_RESET_OTP_TTL_MINUTES=15

# SMTP (required in production for forgot-password emails; in development OTP is logged if omitted)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@example.com"
