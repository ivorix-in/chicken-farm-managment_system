enum SellerType {
  BUSINESS
  INDIVIDUAL
}

enum SellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum AddressType {
  BUSINESS
  WAREHOUSE
  PICKUP
  RETURN
}

model Seller {
  id           String                   @id @default(uuid())
  firstName    String
  lastName     String
  email        String                   @unique
  password     String
  phoneNumber  String                   @unique
  country      String
  sellerType   SellerType
  status       SellerStatus             @default(PENDING)
  isActive     Boolean                  @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  passwordOtps SellerPasswordResetOtp[]
  individualProfile IndividualProfile?
  businessProfile   BusinessProfile?
  addresses    SellerAddress[]

  @@index([email])
  @@index([sellerType])
  @@index([status])
}

model IndividualProfile {
  id       String @id @default(uuid())
  sellerId String @unique
  seller   Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  storeName String?
  bio       String?
  city      String?
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessProfile {
  id       String @id @default(uuid())
  sellerId String @unique
  seller   Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  businessName       String?
  companyLogoUrl     String?
  companyDescription String?
  tradeLicenseUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SellerAddress {
  id      String @id @default(uuid())
  sellerId String
  seller   Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  addressType  AddressType
  fullName     String
  phoneNumber  String
  addressLine1 String
  addressLine2 String?
  landmark     String?
  city         String
  state        String
  country      String
  postalCode   String
  isDefault    Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([sellerId])
  @@index([sellerId, isDefault])
  @@index([sellerId, isActive])
}

model SellerPasswordResetOtp {
  id        String    @id @default(uuid())
  sellerId  String
  otpHash   String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  seller    Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([expiresAt])
}
